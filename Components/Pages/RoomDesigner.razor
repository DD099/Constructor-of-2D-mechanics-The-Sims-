@page "/designer"
@rendermode InteractiveServer

@using System.Drawing
@using System.Globalization
@using SimsConstructor.Models.Building
@using SimsConstructor.Models
@using SimsConstructor.Models.Interfaces
@using SimsConstructor.Models.Items
@using SimsConstructor.Services

@inject RoomService Room
@inject BuildService Build
@inject IJSRuntime JS

<PageTitle>Room designer</PageTitle>

<h1 class="mb-3">Room designer</h1>
<p class="text-muted small mb-3">Use tool mode: move items, build walls, or preview rooms.</p>

@if (!string.IsNullOrEmpty(Room.StatusMessage))
{
    <div class="alert alert-secondary py-2 small mb-3" role="status">@Room.StatusMessage</div>
}

@if (!string.IsNullOrEmpty(Build.StatusMessage))
{
    <div class="alert alert-light py-2 small mb-3" role="status">@Build.StatusMessage</div>
}

<div class="room-designer">
    <div class="room-designer__preview">
        <div class="room-designer__canvas"
             @ref="_canvasRef"
             style="width: @(RoomWidthPx)px; height: @(RoomHeightPx)px;"
             @onclick="ClearSelection"
             @onmousedown="OnCanvasMouseDown"
             @onmousemove="OnCanvasMouseMove"
             @onmouseup="OnCanvasMouseUp"
             @onmouseleave="OnCanvasMouseLeave">
            @foreach (var room in Build.Rooms)
            {
                <div class="room-area"
                     title="Room @room.Index (@room.Area.ToString("0.##", CultureInfo.InvariantCulture)) m²"
                     style="@RoomAreaStyle(room)"></div>
            }

            @foreach (var wall in Build.Walls)
            {
                <div class="wall-seg @(wall.Orientation == WallOrientation.Horizontal ? "wall-seg--h" : "wall-seg--v")"
                     style="@WallSegStyle(wall)"></div>
            }

            @if (_toolMode == ToolMode.BuildWalls && _wallDragging && _wallPreview is not null)
            {
                <div class="wall-seg wall-seg--preview"
                     style="@WallSegStyle(_wallPreview)"></div>
            }

            @foreach (var item in Room.Items)
            {
                <button type="button"
                        @key="item.Id"
                        class="room-item @(item.IsSelected ? "room-item--selected" : null) @((item.IsSelected && Room.IsDragging && !Room.IsDragValid) ? "room-item--invalid" : null) @(_toolMode == ToolMode.BuildWalls ? "room-item--disabled" : null)"
                        style="@ItemButtonStyle(item)"
                        title="@item.Name"
                        @onclick:stopPropagation="true"
                        @onclick="@(() => Select(item))"
                        @onmousedown:stopPropagation="true"
                        @onmousedown="@((e) => StartDrag(item, e))">
                    <span class="visually-hidden">@item.Name</span>
                </button>
            }
        </div>
    </div>

    <aside class="room-designer__sidebar">
        @if (Room.BudgetLimit is { } budgetLimit)
        {
            var total = Room.GetTotalPrice();
            var ratio = budgetLimit > 0m ? (double)(total / budgetLimit) : 0d;
            var barPct = Math.Min(ratio * 100d, 100d);
            var over = Room.IsOverBudget();
            <div class="card mb-3 @(over ? "border-danger" : null)">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Budget</span>
                    <span class="badge @(over ? "text-bg-danger" : "text-bg-light")">
                        @FormatMoney(total) / @FormatMoney(budgetLimit)
                    </span>
                </div>
                <div class="card-body py-2">
                    <div class="progress" style="height: 0.5rem;" role="progressbar"
                         aria-valuemin="0" aria-valuemax="100" aria-valuenow="@((int)barPct)">
                        <div class="progress-bar @(over ? "bg-danger" : "bg-success")"
                             style="width: @barPct.ToString("0.##", CultureInfo.InvariantCulture)%"></div>
                    </div>
                    @if (over)
                    {
                        <p class="small text-danger mb-0 mt-2">Over budget by @FormatMoney(total - budgetLimit).</p>
                    }
                    else if (ratio >= 0.9d)
                    {
                        <p class="small text-warning mb-0 mt-2">Close to the limit.</p>
                    }
                </div>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header">Tools</div>
            <div class="card-body">
                <div class="btn-group btn-group-sm" role="group" aria-label="Tool mode">
                    <button type="button"
                            class="btn btn-outline-primary @( _toolMode == ToolMode.MoveItems ? "active" : null)"
                            @onclick="() => SetToolMode(ToolMode.MoveItems)">
                        Move items
                    </button>
                    <button type="button"
                            class="btn btn-outline-primary @( _toolMode == ToolMode.BuildWalls ? "active" : null)"
                            @onclick="() => SetToolMode(ToolMode.BuildWalls)">
                        Build walls
                    </button>
                </div>

                <div class="form-check form-switch mt-3">
                    <input class="form-check-input"
                           type="checkbox"
                           role="switch"
                           id="eraseWalls"
                           @bind="_eraseWalls"
                           disabled="@(_toolMode != ToolMode.BuildWalls)" />
                    <label class="form-check-label small" for="eraseWalls">Erase walls</label>
                </div>

                <div class="small text-muted mt-2">
                    Walls grid: @Build.GridStepMeters.ToString("0.##", CultureInfo.InvariantCulture) m
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Rooms</span>
                <span class="badge text-bg-light">@Build.Rooms.Count</span>
            </div>
            <div class="card-body p-2">
                @if (Build.Rooms.Count == 0)
                {
                    <div class="text-muted small">Draw closed walls to detect rooms.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var room in Build.Rooms)
                        {
                            <div class="list-group-item small py-2 px-2">
                                Room @room.Index: @room.Area.ToString("0.##", CultureInfo.InvariantCulture) m²
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Items in room</span>
                <span class="badge text-bg-light">Total @FormatMoney(Room.GetTotalPrice())</span>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var item in Room.Items)
                {
                    <button type="button"
                            @key="item.Id"
                            class="list-group-item list-group-item-action @(item.IsSelected ? "active" : null)"
                            @onclick="@(() => Select(item))">
                        <span class="fw-semibold d-block">@item.Name</span>
                        <span class="small text-muted">@KindLabel(item)</span>
                    </button>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">Catalog</div>
            <div class="card-body">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" role="switch" id="snapGrid" @bind="Room.SnapToGrid" />
                    <label class="form-check-label small" for="snapGrid">Snap to grid</label>
                </div>
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text">Grid (m)</span>
                    <input class="form-control" inputmode="decimal" @bind="_gridStep" @bind:event="oninput" />
                    <button type="button" class="btn btn-outline-secondary" @onclick="ApplyGridStep">Apply</button>
                </div>
                <div class="d-grid gap-2">
                    @foreach (var t in Room.Catalog)
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                title="@t.Category"
                                @onclick="@(() => AddFromCatalog(t.Id))">
                            + @t.Title
                        </button>
                    }
                </div>
            </div>
        </div>

        @if (Room.GetSelected() is { } selected)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Selected</span>
                    @if (selected is SimsConstructor.Models.Interfaces.IPricable p)
                    {
                        <span class="badge text-bg-light">@FormatMoney(p.GetPrice())</span>
                    }
                </div>
                <div class="card-body small">
                    <div class="fw-semibold">@selected.Name</div>
                    <div class="text-muted">@KindLabel(selected)</div>
                    <hr class="my-2" />
                    <div><span class="text-muted">Size:</span> @selected.Width.ToString("0.##", CultureInfo.InvariantCulture) × @selected.Height.ToString("0.##", CultureInfo.InvariantCulture) m</div>
                    <div><span class="text-muted">Rotation:</span> @selected.Rotation°</div>
                    <div><span class="text-muted">Placed:</span> @(selected.IsPlaced ? "Yes" : "No")</div>
                    @{
                        var selectedCenterX = selected.X + selected.Width / 2f;
                        var selectedCenterY = selected.Y + selected.Height / 2f;
                        var selectedRoom = Build.GetRoomAt(selectedCenterX, selectedCenterY);
                    }
                    <div><span class="text-muted">Room:</span> @(selectedRoom is null ? "None" : selectedRoom.Index.ToString(CultureInfo.InvariantCulture))</div>
                    <div class="d-grid mt-2">
                        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="DeleteSelected">
                            Delete selected
                        </button>
                    </div>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">Placement</div>
            <div class="card-body">
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="form-label small mb-0" for="placeX">X (m)</label>
                        <input id="placeX" class="form-control form-control-sm" @bind="_placeX" @bind:event="oninput" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-0" for="placeY">Y (m)</label>
                        <input id="placeY" class="form-control form-control-sm" @bind="_placeY" @bind:event="oninput" />
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="ApplyPlacement">Place selected</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Rotate">Rotate 90°</button>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Layout file</div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-outline-primary btn-sm" @onclick="ExportLayout">
                        Export JSON
                    </button>
                    <label class="form-label small mb-0" for="layoutImport">Import JSON</label>
                    <InputFile id="layoutImport" class="form-control form-control-sm"
                               accept=".json,application/json"
                               OnChange="ImportLayout" />
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    private const float ScalePxPerUnit = 50f;

    private enum ToolMode
    {
        MoveItems,
        BuildWalls
    }

    private ToolMode _toolMode = ToolMode.MoveItems;
    private bool _eraseWalls;

    private const float WallThicknessPx = 8f;

    private bool _wallDragging;
    private float _wallStartX;
    private float _wallStartY;
    private WallSegment? _wallPreview;

    private string _placeX = "0";
    private string _placeY = "0";
    private string _gridStep = "0.25";
    private ElementReference _canvasRef;
    private bool _dragging;
    private float _dragOffsetXpx;
    private float _dragOffsetYpx;

    private int RoomWidthPx => (int)(Room.WidthUnits * ScalePxPerUnit);
    private int RoomHeightPx => (int)(Room.HeightUnits * ScalePxPerUnit);

    protected override void OnInitialized()
    {
        Room.EnsureSampleRoom();
        Build.GridStepMeters = Room.GridStepMeters;
        SyncInputsFromSelection();
    }

    private void SetToolMode(ToolMode mode)
    {
        _toolMode = mode;
        if (_toolMode == ToolMode.BuildWalls)
        {
            Room.ClearSelection();
            _placeX = "0";
            _placeY = "0";
        }

        StateHasChanged();
    }

    private void Select(RoomItem item)
    {
        if (_toolMode != ToolMode.MoveItems)
            return;

        Room.Select(item);
        SyncInputsFromSelection();
    }

    private async Task StartDrag(RoomItem item, MouseEventArgs e)
    {
        if (_toolMode != ToolMode.MoveItems)
            return;

        Room.Select(item);
        SyncInputsFromSelection();

        if (!Room.BeginDragSelected())
            return;

        var pos = await GetCanvasPos(e.ClientX, e.ClientY);
        _dragOffsetXpx = pos.X - (item.X * ScalePxPerUnit);
        _dragOffsetYpx = pos.Y - (item.Y * ScalePxPerUnit);
        _dragging = true;
    }

    private async Task OnCanvasMouseDown(MouseEventArgs e)
    {
        if (_toolMode != ToolMode.BuildWalls)
            return;

        if (e.Button != 0)
            return;

        var pos = await GetCanvasPos(e.ClientX, e.ClientY);
        var x = pos.X / ScalePxPerUnit;
        var y = pos.Y / ScalePxPerUnit;

        _wallDragging = true;
        _wallStartX = SnapToWallGrid(x);
        _wallStartY = SnapToWallGrid(y);
        UpdateWallPreview(x, y);
    }

    private async Task OnCanvasMouseMove(MouseEventArgs e)
    {
        if (_toolMode == ToolMode.BuildWalls)
        {
            if (!_wallDragging)
                return;

            var pos2 = await GetCanvasPos(e.ClientX, e.ClientY);
            var x2 = pos2.X / ScalePxPerUnit;
            var y2 = pos2.Y / ScalePxPerUnit;
            UpdateWallPreview(x2, y2);
            StateHasChanged();
            return;
        }

        if (!_dragging)
            return;

        var pos = await GetCanvasPos(e.ClientX, e.ClientY);
        var x = (pos.X - _dragOffsetXpx) / ScalePxPerUnit;
        var y = (pos.Y - _dragOffsetYpx) / ScalePxPerUnit;
        Room.UpdateDrag(x, y);
        SyncInputsFromSelection();
        StateHasChanged();
    }

    private void OnCanvasMouseUp()
    {
        if (_toolMode == ToolMode.BuildWalls)
        {
            if (!_wallDragging)
                return;

            _wallDragging = false;
            TryCommitWallPreview();
            _wallPreview = null;
            StateHasChanged();
            return;
        }

        if (!_dragging)
            return;

        _dragging = false;
        Room.EndDrag(commit: true);
        SyncInputsFromSelection();
    }

    private void OnCanvasMouseLeave()
    {
        if (_toolMode == ToolMode.BuildWalls)
        {
            if (!_wallDragging)
                return;

            _wallDragging = false;
            _wallPreview = null;
            StateHasChanged();
            return;
        }

        if (!_dragging)
            return;

        _dragging = false;
        Room.EndDrag(commit: true);
        SyncInputsFromSelection();
    }

    private float SnapToWallGrid(float value)
    {
        var step = Build.GridStepMeters;
        if (step <= 0f)
            return value;

        return MathF.Round(value / step) * step;
    }

    private static float Clamp(float value, float min, float max) =>
        value < min ? min : (value > max ? max : value);

    private void UpdateWallPreview(float currentX, float currentY)
    {
        if (!_wallDragging)
            return;

        var step = Build.GridStepMeters;
        if (step <= 0f)
        {
            _wallPreview = null;
            return;
        }

        var sx = _wallStartX;
        var sy = _wallStartY;

        var cx = SnapToWallGrid(currentX);
        var cy = SnapToWallGrid(currentY);

        cx = Clamp(cx, 0f, Build.RoomWidthUnits);
        cy = Clamp(cy, 0f, Build.RoomHeightUnits);

        var dx = cx - sx;
        var dy = cy - sy;

        if (MathF.Abs(dx) < step * 0.25f && MathF.Abs(dy) < step * 0.25f)
        {
            _wallPreview = null;
            return;
        }

        if (MathF.Abs(dx) >= MathF.Abs(dy))
        {
            // Horizontal wall
            var xMin = MathF.Min(sx, cx);
            var xMax = MathF.Max(sx, cx);
            if (xMax - xMin < step * 0.5f)
            {
                _wallPreview = null;
                return;
            }

            _wallPreview = new WallSegment(WallOrientation.Horizontal, xMin, sy, xMax, sy);
        }
        else
        {
            // Vertical wall
            var yMin = MathF.Min(sy, cy);
            var yMax = MathF.Max(sy, cy);
            if (yMax - yMin < step * 0.5f)
            {
                _wallPreview = null;
                return;
            }

            _wallPreview = new WallSegment(WallOrientation.Vertical, sx, yMin, sx, yMax);
        }
    }

    private void TryCommitWallPreview()
    {
        if (_wallPreview is null)
            return;

        var x1 = _wallPreview.X1;
        var y1 = _wallPreview.Y1;
        var x2 = _wallPreview.X2;
        var y2 = _wallPreview.Y2;

        if (_eraseWalls)
        {
            if (!Build.TryEraseWallSegment(x1, y1, x2, y2, out var err))
                Build.SetStatus(err ?? "Cannot erase wall.");
            else
                Build.SetStatus("Wall erased.");
        }
        else
        {
            if (!Build.TryAddWallSegment(x1, y1, x2, y2, out var err))
                Build.SetStatus(err ?? "Cannot add wall.");
            else
                Build.SetStatus("Wall added.");
        }
    }

    private void ClearSelection()
    {
        if (_toolMode != ToolMode.MoveItems)
            return;

        Room.ClearSelection();
        SyncInputsFromSelection();
    }

    private void SyncInputsFromSelection()
    {
        var selected = Room.GetSelected();
        if (selected is null)
        {
            _placeX = "0";
            _placeY = "0";
            return;
        }

        _placeX = selected.X.ToString(CultureInfo.InvariantCulture);
        _placeY = selected.Y.ToString(CultureInfo.InvariantCulture);
    }

    private void ApplyPlacement()
    {
        if (!float.TryParse(_placeX, NumberStyles.Float, CultureInfo.InvariantCulture, out var x)
            || !float.TryParse(_placeY, NumberStyles.Float, CultureInfo.InvariantCulture, out var y))
        {
            Room.SetStatus("Invalid X or Y.");
            return;
        }

        Room.TryPlaceSelected(x, y);
        SyncInputsFromSelection();
    }

    private void ApplyGridStep()
    {
        if (float.TryParse(_gridStep, NumberStyles.Float, CultureInfo.InvariantCulture, out var step) && step > 0f)
        {
            Room.GridStepMeters = step;
            Build.GridStepMeters = step;
            Room.SetStatus($"Grid step: {step.ToString("0.##", CultureInfo.InvariantCulture)} m");
        }
        else
        {
            Room.SetStatus("Invalid grid step.");
        }
    }

    private void Rotate()
    {
        Room.TryRotateSelected();
        SyncInputsFromSelection();
    }

    private void AddFromCatalog(string id)
    {
        Room.TryAddFromCatalog(id);
        SyncInputsFromSelection();
    }

    private void DeleteSelected()
    {
        Room.RemoveSelected();
        SyncInputsFromSelection();
    }

    private async Task ExportLayout()
    {
        var json = Room.ExportLayoutJson();
        await JS.InvokeVoidAsync("simsDownloadText", "room-layout.json", json);
        Room.SetStatus("Exported room-layout.json.");
    }

    private async Task ImportLayout(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
            return;

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 2_000_000);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            if (!Room.TryImportLayoutJson(json, out var err))
            {
                Room.SetStatus(err ?? "Import failed.");
            }

            SyncInputsFromSelection();
        }
        catch (Exception ex)
        {
            Room.SetStatus(ex.Message);
        }

        StateHasChanged();
    }

    private string RoomAreaStyle(RoomArea room) =>
        $"left:{(room.X * ScalePxPerUnit).ToString(CultureInfo.InvariantCulture)}px;" +
        $"top:{(room.Y * ScalePxPerUnit).ToString(CultureInfo.InvariantCulture)}px;" +
        $"width:{(room.Width * ScalePxPerUnit).ToString(CultureInfo.InvariantCulture)}px;" +
        $"height:{(room.Height * ScalePxPerUnit).ToString(CultureInfo.InvariantCulture)}px;";

    private string WallSegStyle(WallSegment wall)
    {
        var half = WallThicknessPx / 2f;
        if (wall.Orientation == WallOrientation.Horizontal)
        {
            var left = wall.MinX * ScalePxPerUnit;
            var top = wall.Y1 * ScalePxPerUnit - half;
            var width = wall.Length * ScalePxPerUnit;
            return $"left:{left.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"top:{top.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"width:{width.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"height:{WallThicknessPx.ToString(CultureInfo.InvariantCulture)}px;";
        }

        // Vertical
        {
            var left = wall.X1 * ScalePxPerUnit - half;
            var top = wall.MinY * ScalePxPerUnit;
            var height = wall.Length * ScalePxPerUnit;
            return $"left:{left.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"top:{top.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"width:{WallThicknessPx.ToString(CultureInfo.InvariantCulture)}px;" +
                   $"height:{height.ToString(CultureInfo.InvariantCulture)}px;";
        }
    }

    private static string KindLabel(RoomItem item) => item switch
    {
        FurnitureItem f => $"Furniture · {f.Category}",
        ApplianceItem => "Appliance",
        DecorationItem d => $"Decoration · {d.Style}",
        _ => item.GetType().Name
    };

    private async Task<CanvasPos> GetCanvasPos(double clientX, double clientY) =>
        await JS.InvokeAsync<CanvasPos>("simsGetRelativePos", _canvasRef, clientX, clientY);

    private sealed class CanvasPos
    {
        public float X { get; set; }
        public float Y { get; set; }
    }

    private string ItemButtonStyle(RoomItem item)
    {
        var left = item.X * ScalePxPerUnit;
        var top = item.Y * ScalePxPerUnit;
        var w = item.Width * ScalePxPerUnit;
        var h = item.Height * ScalePxPerUnit;
        var fill = Rgb(item.Color);

        return $"left:{left.ToString(CultureInfo.InvariantCulture)}px;" +
               $"top:{top.ToString(CultureInfo.InvariantCulture)}px;" +
               $"width:{w.ToString(CultureInfo.InvariantCulture)}px;" +
               $"height:{h.ToString(CultureInfo.InvariantCulture)}px;" +
               $"--item-fill:{fill};";
    }

    private static string Rgb(Color color) =>
        $"rgb({color.R}, {color.G}, {color.B})";

    private static string FormatMoney(decimal value) =>
        value.ToString("0.##", CultureInfo.InvariantCulture);
}
