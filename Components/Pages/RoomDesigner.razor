@page "/designer"
@rendermode InteractiveServer

@using System.Drawing
@using System.Globalization
@using SimsConstructor.Models
@using SimsConstructor.Models.Items
@using SimsConstructor.Services

@inject RoomService Room

<PageTitle>Room designer</PageTitle>

<h1 class="mb-3">Room designer</h1>
<p class="text-muted small mb-4">Select an item, set X/Y, place or rotate.</p>

@if (!string.IsNullOrEmpty(Room.StatusMessage))
{
    <div class="alert alert-secondary py-2 small mb-3" role="status">@Room.StatusMessage</div>
}

<div class="room-designer">
    <div class="room-designer__preview">
        <div class="room-designer__canvas"
             style="width: @(RoomWidthPx)px; height: @(RoomHeightPx)px;">
            @foreach (var item in Room.Items)
            {
                <button type="button"
                        @key="item.Id"
                        class="room-item @(item.IsSelected ? "room-item--selected" : null)"
                        style="@ItemButtonStyle(item)"
                        title="@item.Name"
                        @onclick="@(() => Select(item))">
                    <span class="visually-hidden">@item.Name</span>
                </button>
            }
        </div>
    </div>

    <aside class="room-designer__sidebar">
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Items in room</span>
                <span class="badge text-bg-light">Total @FormatMoney(Room.GetTotalPrice())</span>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var item in Room.Items)
                {
                    <button type="button"
                            @key="item.Id"
                            class="list-group-item list-group-item-action @(item.IsSelected ? "active" : null)"
                            @onclick="@(() => Select(item))">
                        <span class="fw-semibold d-block">@item.Name</span>
                        <span class="small text-muted">@KindLabel(item)</span>
                    </button>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header">Placement</div>
            <div class="card-body">
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="form-label small mb-0" for="placeX">X (m)</label>
                        <input id="placeX" class="form-control form-control-sm" @bind="_placeX" @bind:event="oninput" />
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-0" for="placeY">Y (m)</label>
                        <input id="placeY" class="form-control form-control-sm" @bind="_placeY" @bind:event="oninput" />
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary btn-sm" @onclick="ApplyPlacement">Place selected</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="Rotate">Rotate 90°</button>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    private const float ScalePxPerUnit = 50f;

    private string _placeX = "0";
    private string _placeY = "0";

    private int RoomWidthPx => (int)(Room.WidthUnits * ScalePxPerUnit);
    private int RoomHeightPx => (int)(Room.HeightUnits * ScalePxPerUnit);

    protected override void OnInitialized()
    {
        Room.EnsureSampleRoom();
        SyncInputsFromSelection();
    }

    private void Select(RoomItem item)
    {
        Room.Select(item);
        SyncInputsFromSelection();
    }

    private void SyncInputsFromSelection()
    {
        var selected = Room.GetSelected();
        if (selected is null)
            return;

        _placeX = selected.X.ToString(CultureInfo.InvariantCulture);
        _placeY = selected.Y.ToString(CultureInfo.InvariantCulture);
    }

    private void ApplyPlacement()
    {
        if (!float.TryParse(_placeX, NumberStyles.Float, CultureInfo.InvariantCulture, out var x)
            || !float.TryParse(_placeY, NumberStyles.Float, CultureInfo.InvariantCulture, out var y))
        {
            Room.SetStatus("Invalid X or Y.");
            return;
        }

        Room.TryPlaceSelected(x, y);
        SyncInputsFromSelection();
    }

    private void Rotate()
    {
        Room.TryRotateSelected();
        SyncInputsFromSelection();
    }

    private static string KindLabel(RoomItem item) => item switch
    {
        FurnitureItem f => $"Furniture · {f.Category}",
        ApplianceItem => "Appliance",
        DecorationItem d => $"Decoration · {d.Style}",
        _ => item.GetType().Name
    };

    private string ItemButtonStyle(RoomItem item)
    {
        var left = item.X * ScalePxPerUnit;
        var top = item.Y * ScalePxPerUnit;
        var w = item.Width * ScalePxPerUnit;
        var h = item.Height * ScalePxPerUnit;
        var fill = Rgb(item.Color);

        return $"left:{left.ToString(CultureInfo.InvariantCulture)}px;" +
               $"top:{top.ToString(CultureInfo.InvariantCulture)}px;" +
               $"width:{w.ToString(CultureInfo.InvariantCulture)}px;" +
               $"height:{h.ToString(CultureInfo.InvariantCulture)}px;" +
               $"--item-fill:{fill};";
    }

    private static string Rgb(Color color) =>
        $"rgb({color.R}, {color.G}, {color.B})";

    private static string FormatMoney(decimal value) =>
        value.ToString("0.##", CultureInfo.InvariantCulture);
}
